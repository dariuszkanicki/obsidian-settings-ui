{
  "name": "@dkani/obsidian-settings-ui",
  "version": "1.0.2",
  "description": "Reusable UI components for Obsidian plugin settings",
  "type": "module",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    "import": "./dist/lib/index.js",
    "types": "./dist/lib/index.d.ts"
  },
  "scripts": {
    "test:inject": "pnpm build && node dist/lib/bin/inject-prefixed-styles.js",
    "build": "node build.mjs",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "bin": {
    "dkani-inject-styles": "./dist/lib/bin/inject-prefixed-styles.js"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "settings",
    "ui"
  ],
  "author": "Dariusz Kanicki",
  "license": "MIT",
  "files": [
    "dist/lib",
    "styles/source-styles.css"
  ],
  "dependencies": {
    "lucide": "^0.487.0",
    "lucide-static": "^0.487.0",
    "obsidian": "*"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/postcss-prefix-selector": "^1.16.3",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "cpx": "^1.5.0",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-flat-config-utils": "^2.0.1",
    "eslint-plugin-prettier": "^5.2.6",
    "jiti": "^2.4.2",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "postcss-prefix-selector": "^2.1.1",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
